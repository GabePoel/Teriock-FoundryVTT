{
  "includes": [
    "**/*.json",
    "**/*.md",
    "**/*.scss",
    "**/*.svg",
    "**/*.{mjs,ts}"
  ],
  "json": {
    "indentWidth": 2,
    "useTabs": false
  },
  "lineWidth": 120,
  "malva": {
    "declarationOrder": "alphabetical",
    "indentWidth": 2,
    "operatorLinebreak": "after",
    "quotes": "alwaysDouble",
    "trailingComma": true
  },
  "plugins": [
    "https://plugins.dprint.dev/g-plane/malva-v0.15.3.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/kjanat/svg-v0.4.1.wasm",
    "https://plugins.dprint.dev/markdown-0.22.0.wasm",
    "https://plugins.dprint.dev/typescript-0.93.0.wasm"
  ],
  "svg": {
    "attributeLayout": "multi-line",
    "attributeSort": "canonical",
    "indentWidth": 2,
    "quoteStyle": "double",
    "spaceBeforeSelfClose": true,
    "wrappedAttributeIndent": "one-level"
  },
  "typescript": {
    "indentWidth": 2,
    "module.sortExportDeclarations": "maintain",
    "module.sortImportDeclarations": "maintain",
    "preferSingleLine": true,
    "quoteStyle": "alwaysDouble",
    "semiColons": "always",
    "singleBodyPosition": "sameLine",
    "trailingCommas": "onlyMultiLine",
    "typeLiteral.separatorKind.singleLine": "comma",
    "useBraces": "always",
    "useTabs": false
  },
  "yaml": {
    "printWidth": 120
  }
}
