{
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "plugins": ["prettier-plugin-organize-attributes", "@poliklot/prettier-plugin-handlebars"],
  "overrides": [
    {
      "files": "*.hbs",
      "options": {
        "parser": "handlebars"
      }
    }
  ]
}
