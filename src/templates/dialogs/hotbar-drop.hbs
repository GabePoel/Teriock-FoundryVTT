<div class="teriock" style="display: flex; flex-direction: column; gap: 14px;">
  <div class="form-group">
    <label>{{localize "TERIOCK.DIALOGS.HotbarDrop.BUTTONS.general"}}</label>
    <p class="hint">
      {{localize
        "TERIOCK.DIALOGS.HotbarDrop.general.hint"
        identifier=identifier
        label=label
        name=name
      }}
    </p>
  </div>
  <div class="form-group">
    <label>{{localize "TERIOCK.DIALOGS.HotbarDrop.BUTTONS.linked"}}</label>
    <p class="hint">
      {{localize
        "TERIOCK.DIALOGS.HotbarDrop.linked.hint"
        child=child
        actor=actor
      }}
    </p>
  </div>
</div>
