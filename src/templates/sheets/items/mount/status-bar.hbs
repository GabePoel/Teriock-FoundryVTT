<div class="ab-bar">
  {{> "teriock/sheets/shared/forms/tier-form"}}
  {{formBox
    (formInput
      systemFields.mountType
      value=system.mountType
      disabled=(not editable)
      placeholder=(localize "TERIOCK.SYSTEMS.Mount.FIELDS.mountType.label")
    )
    unselected=(inferName system.mountType "mount")
    tooltip=(localize "TERIOCK.SYSTEMS.Mount.FIELDS.mountType.label")
    icon=TERIOCK.config.document.species.icon
  }}
</div>