<div class="tgrid-item">
  <div class="ab-multi-select-label">
    <label class="tsubtle" for="{{concat appId "-" field.name}}">{{field.label}}</label>
    {{formInput
      field
      value=value
      rootId=appId
      id=(concat @root/appId "-" field.name)
      disabled=(not @root/editable)
    }}
  </div>
</div>
