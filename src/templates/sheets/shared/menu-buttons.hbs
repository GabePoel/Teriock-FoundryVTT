{{#if canHaveMechanics}}
  <div class="ab-icon ab-mechanics-toggle">
    <div
      class="ab-menu-mechanics-container"
      data-tooltip='{{localize "TERIOCK.SHEETS.Common.NAVIGATION.enterMechanicsTab"}}'
      data-action="toggleMechanics"
    >
      {{makeIcon TERIOCK.display.icons.pseudoDocument.mechanic "solid"}}
    </div>
  </div>
{{/if}}
{{#if hasMenu}}
  <div
    class="
      ab-icon
      ab-menu-toggle
      {{#if (not menuCollapsed)}}
        ab-menu-toggle-open
      {{/if}}
    "
    data-action="toggleMenu"
  >
    <div class="ab-menu-closed-container" data-tooltip='{{localize "TERIOCK.SHEETS.Common.NAVIGATION.openMenu"}}'>
      {{makeIcon TERIOCK.display.icons.ui.menuOpen "solid"}}
    </div>
    <div class="ab-menu-open-container" data-tooltip='{{localize "TERIOCK.SHEETS.Common.NAVIGATION.closeMenu"}}'>
      {{makeIcon TERIOCK.display.icons.ui.menuClose "solid"}}
    </div>
  </div>
{{/if}}
