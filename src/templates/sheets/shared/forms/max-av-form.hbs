{{formBox
  (formInput
    systemFields.maxAv
    value=system.maxAv
    placeholder="0"
    disabled=(not editable))
  icon=TERIOCK.display.icons.armament.av
  unselected=(ifThen
    (exists system.maxAv)
    (localize "TERIOCK.SYSTEMS.Power.PANELS.maxAv" value=system.maxAv)
    (localize "TERIOCK.SYSTEMS.Power.PANELS.noArmor"))
  tooltip=(localize "TERIOCK.SYSTEMS.BaseItem.FIELDS.maxAv.label")
}}
