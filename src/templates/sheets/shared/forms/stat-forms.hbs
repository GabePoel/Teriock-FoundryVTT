{{#each TERIOCK.config.stat as |config key|}}
  {{#if config.pool.enabled}}
    {{
      formBox
      (localize
        "TERIOCK.MODELS.BaseStatPool.PANELS.summary"
        formula=(path @root/system.statDice key "formula")
        value=(path @root/system.statDice key "value"))
      action="setStatDice"
      dataset=(object stat=key)
      icon=config.icon
      tooltip=(localize (concat "TERIOCK.SYSTEMS.StatGiver.FIELDS.statDice." key ".label"))
      label=(localize config.abbreviation)
      overflow=true
    }}
  {{/if}}
{{/each}}
