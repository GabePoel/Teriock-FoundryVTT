{{formBox
  (concat
    system.statDice.hp.formula " "
    " (" system.statDice.hp.value ")")
  action="setStatDice"
  dataset=(object stat="hp")
  icon=TERIOCK.display.icons.stat.hp
  tooltip=(localize "TERIOCK.SYSTEMS.StatGiver.FIELDS.statDice.hp.label")
  label=(localize "TERIOCK.STATS.hp.abbreviation")
  overflow=true
}}
