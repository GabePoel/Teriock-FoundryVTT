{{#if system.consumable}}
  <div class="ab-bar">
    {{formBox
      (formInput
        systemFields.quantity
        disabled=(not editable)
        value=system.quantity
      )
      icon=TERIOCK.display.icons.ui.quantity
      unselected=(localize "TERIOCK.SYSTEMS.Consumable.EMBED.remaining" value=system.quantity)
      tooltip=(localize "TERIOCK.SYSTEMS.Consumable.FIELDS.quantity.label")
    }}
    {{formBox
      (formInput
        systemFields.maxQuantity
        disabled=(not editable)
        value=system._source.maxQuantity.raw
        placeholder=(localize "TERIOCK.SYSTEMS.Consumable.PANELS.noMax")
      )
      icon=TERIOCK.display.icons.ui.maximum
      unselected=(ifThen
        system.maxQuantity.raw
        (localize
          "TERIOCK.SYSTEMS.Consumable.PANELS.max"
          value=system.maxQuantity.value
        )
        ""
      )
      tooltip=(localize "TERIOCK.SYSTEMS.Consumable.FIELDS.maxQuantity.raw.label")
    }}
    {{formBox
      (formInput
        systemFields.consumptionAmount
        disabled=(not editable)
        value=system.consumptionAmount
        placeholder="0"
      )
      icon=TERIOCK.display.icons.ui.amount
      unselected=(localize "TERIOCK.SYSTEMS.Consumable.EMBED.perUse" value=system.consumptionAmount)
      tooltip=(localize "TERIOCK.SYSTEMS.Consumable.FIELDS.consumptionAmount.label")
    }}
  </div>
{{/if}}