{{#if (or
  (exists system.attackPenalty)
  (exists system.damage.base)
  (exists system.damage.twoHanded)
  (exists system.hitBonus))
}}
  <div class="ab-bar">
    {{formBox
      (formInput
        systemFields.damage.fields.base
        dataset=(object
          tooltip=(ifThen
            (exists system._source.damage.twoHanded)
            (localize "TERIOCK.SYSTEMS.Armament.FIELDS.damage.label")
            ""))
        disabled=(not editable)
        value=system._source.damage.base)
      secondary=(formInput
        (ifThen
          (exists system._source.damage.twoHanded)
          systemFields.damage.fields.twoHanded
          systemFields.damage.fields.base)
        dataset=(object tooltip=(localize "TERIOCK.SYSTEMS.Armament.FIELDS.damage.twoHanded.label"))
        disabled=(not editable)
        value=system._source.damage.twoHanded)
      icon=TERIOCK.display.icons.ui.damage
      include=(exists system.damage.base)
      includeSecondary=(exists system._source.damage.twoHanded)
      label=(localize "TERIOCK.SYSTEMS.Armament.FIELDS.damage.abbreviation")
      tooltip=(localize "TERIOCK.SYSTEMS.Armament.FIELDS.damage.label")
    }}
    {{formBox
      (formInput
        systemFields.hitBonus
        disabled=(not editable)
        value=system._source.hitBonus)
      icon=TERIOCK.display.icons.armament.hitBonus
      include=(exists system.hitBonus)
      label=(localize "TERIOCK.SYSTEMS.Attack.FIELDS.hitBonus.abbreviation")
      unselected=system.hitBonus
      tooltip=(localize "TERIOCK.SYSTEMS.Attack.FIELDS.hitBonus.label")
    }}
    {{formBox
      (formInput
        systemFields.attackPenalty
        disabled=(not editable)
        value=system._source.attackPenalty)
      icon=TERIOCK.display.icons.armament.ap
      label=(localize "TERIOCK.SYSTEMS.Attack.FIELDS.attackPenalty.abbreviation")
      unselected=system.attackPenalty
      tooltip=(localize "TERIOCK.SYSTEMS.Attack.FIELDS.attackPenalty.label")
    }}
  </div>
{{/if}}
{{#if (or
  (exists system.av.raw)
  (exists system.bv.raw))
}}
  <div class="ab-bar">
    {{formBox
      (formInput
        systemFields.av
        disabled=(not editable)
        value=system._source.av.raw)
      icon=TERIOCK.display.icons.armament.av
      include=(exists system.av.raw)
      label=(localize "TERIOCK.SYSTEMS.Armament.FIELDS.av.abbreviation")
      unselected=system.av.value
      tooltip=(localize "TERIOCK.SYSTEMS.Armament.FIELDS.av.raw.label")
    }}
    {{formBox
      (formInput
        systemFields.bv
        disabled=(not editable)
        value=system._source.bv.raw)
      icon=TERIOCK.display.icons.armament.bv
      include=(exists system.bv.raw)
      label=(localize "TERIOCK.SYSTEMS.Armament.FIELDS.bv.abbreviation")
      unselected=system.bv.value
      tooltip=(localize "TERIOCK.SYSTEMS.Armament.FIELDS.bv.raw.label")
    }}
  </div>
{{/if}}
