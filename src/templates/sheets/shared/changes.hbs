{{!--
  Reusable changes template. This is generalized so that it works for the default `ActiveEffect` changes as well as
  custom arrays that have the same basic format.

  Parameters (and default values for normal `ActiveEffect` changes):
  - changesPath: "changes"
  - changesData: (path document "changes")
  - fieldDefs: (path fields "changes.element.fields")
  - additionalAttrs: Not actually needed for default changes. This is for abilities mainly.
--}}

<ol class="change-config-container" data-changes>
  {{#each changesData as |change i|}}
    {{#with ../fieldDefs as |changeFields|}}
      <li class="change-container" data-index="{{i}}" data-path="{{../../changesPath}}">
        <div class="change-entry">
          {{formInput
            changeFields.key
            name=""
            value=change.key
            disabled=(not @root/editable)
            icon=@root/TERIOCK.display.icons.change.key
            id=(concat @root/appId ../../changesPath "." i ".key")
            classes="teriock-change-input"
            dataset=(object
              tooltip=change.key
              property="key"
            )
          }}
          {{formInput
            changeFields.value
            name=""
            value=change.value
            icon=@root/TERIOCK.display.icons.change.value
            disabled=(not @root/editable)
            id=(concat @root/appId ../../changesPath "." i ".value")
            classes="teriock-change-input"
            dataset=(object
              tooltip=change.value
              property="value"
            )
          }}
        </div>
        <div class="change-config">
          <div class="change-activation">
            {{formInput
              changeFields.qualifier
              name=""
              value=change.qualifier
              disabled=(not @root/editable)
              icon=@root/TERIOCK.display.icons.ui.qualifier
              id=(concat @root/appId ../../changesPath "." i ".qualifier")
              classes="teriock-change-input formula-input"
              dataset=(object
                tooltip=change.qualifier
                property="qualifier"
              )
            }}
            {{formInput
              changeFields.priority
              name=""
              value=change.priority
              icon=@root/TERIOCK.display.icons.change.priority
              placeholder=(lookup ../../priorities change.mode)
              disabled=(not @root/editable)
              id=(concat @root/appId ../../changesPath "." i ".priority")
              classes="teriock-change-input"
              dataset=(object
                tooltip=change.priority
                property="priority"
              )
            }}
          </div>
          <div class="change-assignment">
            {{formInput
              changeFields.type
              name=""
              value=change.type
              icon=@root/TERIOCK.display.icons.change.type
              disabled=(not @root/editable)
              id=(concat @root/appId ../../changesPath "." i ".type")
              classes="teriock-change-input"
              dataset=(object
                property="type"
              )
            }}
            {{formInput
              changeFields.target
              name=""
              value=change.target
              icon=@root/TERIOCK.display.icons.change.target
              disabled=(not @root/editable)
              id=(concat @root/appId ../../changesPath "." i ".target")
              classes="teriock-change-input"
              dataset=(object
                property="target"
              )
            }}
            {{formInput
              changeFields.phase
              name=""
              icon=@root/TERIOCK.display.icons.change.phase
              value=change.phase
              disabled=(not @root/editable)
              id=(concat @root/appId ../../changesPath "." i ".phase")
              classes="teriock-change-input"
              dataset=(object
                tooltip=(path @root/TERIOCK.options.change.phase change.phase "hint")
                property="phase"
              )
            }}
          </div>
        </div>
        <div class="change-controls">
          <button
            class="change-delete"
            data-action="deleteQualifiedChange"
            data-tooltip="{{localize "TERIOCK.CHANGES.Actions.deleteChange"}}"
            data-index="{{i}}"
            data-path="{{../../changesPath}}"
            data-value-path="{{../../valuePath}}"
            {{#each ../additionalAttrs as |value key|}}data-{{key}}="{{value}}" {{/each}}
            {{#if (not @root/editable)}}disabled="disabled"{{/if}}
          >
            {{makeIcon @root/TERIOCK.display.icons.ui.delete "button"}}
          </button>
        </div>
      </li>
    {{/with}}
  {{/each}}
  <button
    class="add-change-button"
    data-action="addQualifiedChange"
    data-path="{{changesPath}}"
    data-value-path="{{valuePath}}"
    {{#each additionalAttrs as |value key|}}data-{{key}}="{{value}}" {{/each}}
    {{#if (not @root/editable)}}disabled="disabled"{{/if}}
  >
    {{makeIcon TERIOCK.display.icons.ui.add "button"}}
    {{localize "TERIOCK.CHANGES.Actions.addChange"}}
  </button>
</ol>