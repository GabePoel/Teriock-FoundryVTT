<div class="ab-menu-bar">
  <div class="ttable ab-check-grid">
    {{#each displayToggles}}
      {{formGroup
        schema
        classes="tgrid-item"
        dataset=dataset
        disabled=(not (and @root/editable editable))
        label=label
        value=value
        rootId=@root/uuid
      }}
    {{/each}}
  </div>
</div>
