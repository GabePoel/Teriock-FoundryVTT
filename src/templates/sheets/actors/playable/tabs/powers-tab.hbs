<div class="character-tab powers">
  <h1>{{localize "TERIOCK.SHEETS.Actor.TABS.Powers.title"}}</h1>
  <div class="character-tab-page teriock-block-results" data-search-key="powers">
    <div class="teriock-block-display">
      <div class="teriock-block-options">
        {{> "teriock/ui/block-options"
          tab="power"
          optionsToggle=settings.menus.powerOptions
          optionsPath="settings.menus.powerOptions"
          searchValue=settings.powerFilters.search
          searchKey="powers"
          addAction="createPower"
          gaplessPath="flags.teriockDocumentSettings.sheet.blockPowersGapless"
          gaplessValue=flags.teriockDocumentSettings.sheet.blockPowersGapless
          sizePath="flags.teriockDocumentSettings.sheet.blockPowersSize"
          sizeValue=flags.teriockDocumentSettings.sheet.blockPowersSize
          tabDisplay=TERIOCK.config.document.power.label
        }}
      </div>
      {{> "teriock/sheets/actors/playable/results/search-results"
        docs=species
        searchKey="powers"
        displayKey="power"
        empty=TERIOCK.config.document.species.plural
        gapless="sheet.blockPowersGapless"
        size="sheet.blockPowersSize"
      }}
      <div class="teriock-block-display-divider"></div>
      {{> "teriock/sheets/actors/playable/results/search-results"
        docs=powers
        searchKey="powers"
        displayKey="power"
        empty=TERIOCK.config.document.power.plural
        gapless="sheet.blockPowersGapless"
        size="sheet.blockPowersSize"
      }}
    </div>
  </div>
</div>