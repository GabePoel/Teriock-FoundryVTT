<div class="character-tab tradecrafts">
  <h1>{{localize "TERIOCK.SHEETS.Actor.TABS.Tradecrafts.title"}}</h1>
  <div class="character-tab-page teriock-block-results" data-search-key="fluencies">
    <div class="teriock-block-display" data-tooltip-direction="LEFT">
      <div class="tradecraft-panels tgrid g2">
        {{#each tradecraftFields as |field index|}}
          {{> "teriock/sheets/actors/playable/parts/tradecrafts-field"
            field=field
            index=index
          }}
        {{/each}}
        {{#each prestigeFields as |field index|}}
          {{> "teriock/sheets/actors/playable/parts/tradecrafts-field"
            field=field
            index=index
          }}
        {{/each}}
      </div>
    </div>
    <div class="teriock-block-display">
      <div class="teriock-block-options">
        {{> "teriock/ui/block-options"
          tab="fluency"
          optionsToggle=settings.menus.fluencyOptions
          optionsPath="settings.menus.fluencyOptions"
          searchValue=settings.fluencyFilters.search
          searchKey="fluencies"
          addAction="createFluency"
          gaplessPath="flags.teriockDocumentSettings.sheet.blockTradecraftsGapless"
          gaplessValue=flags.teriockDocumentSettings.sheet.blockTradecraftsGapless
          sizePath="flags.teriockDocumentSettings.sheet.blockTradecraftsSize"
          sizeValue=flags.teriockDocumentSettings.sheet.blockTradecraftsSize
          tabDisplay=TERIOCK.config.document.fluency.label
        }}
      </div>
      {{> "teriock/sheets/actors/playable/results/search-results"
        docs=fluencies
        searchKey="fluencies"
        displayKey="fluency"
        empty=TERIOCK.config.document.fluency.plural
        gapless="sheet.blockTradecraftsGapless"
        size="sheet.blockTradecraftsSize"
      }}
    </div>
  </div>
</div>
