<div class="actor-tab affinities">
  <h1>{{localize "TERIOCK.SHEETS.Actor.TABS.Affinities.title"}}</h1>
  <div class="actor-tab-page teriock-block-results" data-search-key="affinity">
    <div class="teriock-block-display">
      <div class="tgrid g4 condition-toggle-container">
        {{#each affinityButtons as |b|}}
          <div
            class="condition-toggle"
            data-action="rollAffinity"
            data-affinity-type="{{ b.affinityType }}"
            data-tooltip="{{ b.tooltip }}"
          >
            <div class="condition-image-container">
              <div class="condition-image">
                <img src="{{ b.img }}" alt="" loading="lazy" />
              </div>
            </div>
            <div class="condition-label tsubtle">{{ b.label }}</div>
          </div>
        {{/each}}
      </div>
    </div>
    <div class="teriock-block-display">
      {{> "teriock/ui/preview"
        @root.previews.affinity
      }}
    </div>
  </div>
</div>
