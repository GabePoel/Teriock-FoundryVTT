<div class="character-tab classes">
  <h1>{{localize "TERIOCK.SHEETS.Actor.TABS.Classes.title"}}</h1>
  <div class="character-tab-page teriock-block-results" data-search-key="ranks">
    <div class="teriock-block-display">
      <div class="teriock-block-options">
        {{> "teriock/ui/block-options"
          tab="rank"
          optionsToggle=settings.menus.rankOptions
          optionsPath="settings.menus.rankOptions"
          searchValue=settings.rankFilters.search
          searchKey="ranks"
          addAction="createRank"
          gaplessPath="flags.teriockDocumentSettings.sheet.blockClassesGapless"
          gaplessValue=flags.teriockDocumentSettings.sheet.blockClassesGapless
          sizePath="flags.teriockDocumentSettings.sheet.blockClassesSize"
          sizeValue=flags.teriockDocumentSettings.sheet.blockClassesSize
          tabDisplay=TERIOCK.config.document.rank.name
        }}
      </div>
      {{> "teriock/sheets/actors/playable/results/search-results"
        docs=ranks
        searchKey="ranks"
        displayKey="rank"
        empty=TERIOCK.config.document.rank.plural
        gapless="sheet.blockClassesGapless"
        size="sheet.blockClassesSize"
      }}
      {{#if (exists archetypes)}}
        <div class="teriock-block-display-divider"></div>
        {{> "teriock/sheets/actors/playable/results/search-results"
          docs=archetypes
          searchKey="ranks"
          displayKey="rank"
          empty=TERIOCK.config.document.archetype.plural
          gapless="sheet.blockClassesGapless"
          size="sheet.blockClassesSize"
        }}
      {{/if}}
    </div>
  </div>
</div>
