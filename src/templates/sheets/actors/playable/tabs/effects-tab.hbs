<div class="character-tab conditions">
  <h1>{{localize "TERIOCK.SHEETS.Actor.TABS.Effects.title"}}</h1>
  <div class="character-tab-page teriock-block-results" data-search-key="effects">
    <div class="teriock-block-display">
      <div class="teriock-block-options">
        {{> "teriock/ui/block-options"
          tab="consequence"
          optionsToggle=settings.menus.consequenceOptions
          optionsPath="settings.menus.consequenceOptions"
          searchValue=settings.consequenceFilters.search
          searchKey="effects"
          addAction="createConsequence"
          gaplessPath="system.settings.sheet.blockEffectsGapless"
          gaplessValue=system.settings.sheet.blockEffectsGapless
          sizePath="system.settings.sheet.blockEffectsSize"
          sizeValue=system.settings.sheet.blockEffectsSize
          tabDisplay=TERIOCK.config.document.consequence.label
        }}
      </div>
      {{> "teriock/sheets/actors/playable/results/search-results"
        docs=consequences
        searchKey="effects"
        displayKey="consequence"
        empty=TERIOCK.config.document.consequence.plural
        gapless="sheet.blockEffectsGapless"
        size="sheet.blockEffectsSize"
      }}
      <div class="teriock-block-display-divider"></div>
      {{> "teriock/sheets/actors/playable/results/search-results"
        docs=attunements
        searchKey="effects"
        displayKey="consequence"
        empty=TERIOCK.config.document.attunement.plural
        gapless="sheet.blockEffectsGapless"
        size="sheet.blockEffectsSize"
      }}
      {{#if (exists miscEffects)}}
        <div class="teriock-block-display-divider"></div>
        {{> "teriock/sheets/actors/playable/results/search-results"
          docs=miscEffects
          searchKey="effects"
          displayKey="consequence"
          empty=TERIOCK.config.document.effect.plural
          gapless="sheet.blockEffectsGapless"
          size="sheet.blockEffectsSize"
        }}
      {{/if}}
      <div class="teriock-block-display-divider"></div>
      {{> "teriock/sheets/actors/playable/results/condition-results"}}
    </div>
    <div class="teriock-block-display">
      <div class="tgrid g4 condition-toggle-container">
        {{#each TERIOCK.data.conditions as |condition key|}}
          {{#if (not (eq key "conscious"))}}
            <div
              class="
                condition-toggle
                {{#if (not (includes ../removableConditions key))}}
                  inactive
                {{/if}}
              "
              data-action="toggleCondition"
              data-condition="{{{ key }}}"
              data-tooltip='
                {{localize "TERIOCK.SHEETS.Actor.TABS.Effects.toggle" name=condition.name state=(ifThen
                (includes ../removableConditions key)
                (localize "TERIOCK.SHEETS.Actor.TABS.Effects.off")
                (localize "TERIOCK.SHEETS.Actor.TABS.Effects.on"))}}
              '
            >
              <div class="condition-image-container">
                <div class="condition-image">
                  <img src='{{getImage "conditions" key}}' alt="{{ condition.name }}" loading="lazy" />
                </div>
              </div>
              <div class="condition-label tsubtle">{{ condition.name }}</div>
            </div>
          {{/if}}
        {{/each}}
      </div>
    </div>
  </div>
</div>
