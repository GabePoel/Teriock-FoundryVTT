<div class="actor-hit-bar-container actor-bar-container">
  <div class="actor-hit-bar actor-bar toutline">
    <div class="actor-bar-left" style="width: {{ bars.hp.remaining }}%;"></div>
    <div
      class="actor-bar-temp"
      style="width: {{ bars.hp.temp }}%; {{barTempHide system.hp.value system.hp.max system.hp.temp system.hp.morganti}}"
    ></div>
    <div class="actor-bar-lost" style="width: {{ bars.hp.lost }}%;"></div>
    <div class="actor-bar-morganti" style="width: {{ bars.hp.morganti }}%;"></div>
  </div>
  <div class="actor-bar-overlay" data-action="toggleCollapseRightClick" data-collapsible-target="drawer-hp">
    <div class="actor-bar-overlay-row actor-hit-bar-overlay-row">
      {{numberInput
        system.hp.value
        name="system.hp.value"
        max=system.hp.max
        min=system.hp.min
        class="thover-soft actor-bar-overlay-left actor-bar-overlay-label"
        dataset=(object tooltip=(localize "TERIOCK.SHEETS.Actor.SIDEBAR.Bars.hp.current"))
        disabled=(not takeStatButtons)
      }}
      <div
        class="actor-bar-overlay-max actor-bar-overlay-label"
        data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.Bars.hp.max"}}'
      >
        <span>/ {{ system.hp.max }} +</span>
      </div>
      {{formInput
        systemFields.hp.fields.temp
        value=system.hp.temp
        classes="thover-soft actor-bar-overlay-temp actor-bar-overlay-label"
        dataset=(object tooltip=(localize "TERIOCK.SHEETS.Actor.SIDEBAR.Bars.hp.temp"))
        disabled=(not takeStatButtons)
      }}
    </div>
    {{#if takeStatButtons}}
      <div
        class="take-harm-button thover take-damage-button"
        data-action="takeImpact"
        data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.Bars.hp.take"}}'
        data-impact="damage"
      >
        {{makeIcon TERIOCK.display.icons.effect.damage "light"}}
      </div>
    {{/if}}
  </div>
</div>
