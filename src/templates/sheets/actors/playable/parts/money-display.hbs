<div class="teriock-block-display">
  <div class="money-panels tgrid g3">
    {{#each TERIOCK.config.currency as |currency id|}}
      <div class="money-panel-container">
        <div class="money-icon tcenter timage" data-src="{{lookup @root/currencyImages id}}">
          <img src="{{lookup @root/currencyImages id}}" data-openable="true" alt="" loading="lazy" />
        </div>
        <div class="money-panel tgrid g4">
          {{
            formInput
            (path ../systemFields.money "fields" id)
            value=(path ../system.money id)
            classes="tgrid-item gi1 money-panel-input tgrid-item tcenter"
            dataset=(object tooltip=(minLen (path ../system.money id) 4))
            placeholder="0"
          }}
          <div class="money-info tsubtle tcenter gi3">
            <div class="money-name">{{currency.label}}</div>
            <div class="money-value">
              {{
                localize
                "TERIOCK.SHEETS.Actor.TABS.Inventory.money.value"
                value=currency.conversion
                weight=currency.weight
              }}
            </div>
          </div>
        </div>
      </div>
    {{/each}}
    <div class="money-panel-container">
      <div class="money-icon tcenter timage" data-src="{{ currencyImages.debt }}">
        <img src="{{ currencyImages.debt }}" data-openable="true" alt="" loading="lazy" />
      </div>
      <div class="money-panel tgrid g4">
        {{
          formInput
          systemFields.money.fields.debt
          value=system.money.debt
          classes="tgrid-item gi1 money-panel-input tgrid-item tcenter"
          dataset=(object tooltip=system.money.debt)
          placeholder="0"
        }}
        <div class="money-info tsubtle tcenter gi3">
          <div class="money-name">{{localize "TERIOCK.TERMS.Currency.debt"}}</div>
          <div class="money-value">
            {{
              localize
              "TERIOCK.SYSTEMS.BaseActor.FIELDS.interestRate.daily"
              rate=system.interestRate
            }}
          </div>
        </div>
      </div>
    </div>
  </div>
  <div
    class="
      money-total
      {{#if (lt system.money.total 0)}}
      tred
      {{/if}}
    "
  >
    {{system.money.total}}
    ₲&nbsp;&nbsp;&nbsp;&nbsp;
    {{system.weight.money}}
    lb
  </div>
</div>
