<div class="ch-attribute-box tbox toutline">
  <div class="tgrid g4 tradecraft-panel">
    <div class="attribute-container tgrid g4 gi4" data-tooltip-direction="UP">
      <div
        class="tsubtle tcenter"
        data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.AttributeBox.competence.tooltip"}}'
      >
        {{localize "TERIOCK.SHEETS.Actor.SIDEBAR.AttributeBox.competence.label"}}
      </div>
      <div class="tsubtle tcenter" data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.AttributeBox.name.tooltip"}}'>
        {{localize "TERIOCK.SHEETS.Actor.SIDEBAR.AttributeBox.name.label"}}
      </div>
      <div class="tsubtle tcenter" data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.AttributeBox.score.tooltip"}}'
      >
        {{localize "TERIOCK.SHEETS.Actor.SIDEBAR.AttributeBox.score.label"}}
      </div>
      <div
        class="tsubtle tcenter"
        data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.AttributeBox.modifier.tooltip"}}'
      >
        {{localize "TERIOCK.SHEETS.Actor.SIDEBAR.AttributeBox.modifier.label"}}
      </div>
    </div>
    {{#each TERIOCK.index.attributesFull as |attribute name|}}
      <div
        class="attribute-container tgrid g4 gi4"
        data-tooltip-direction="LEFT"
        data-tooltip-identifier='{{path @root/TERIOCK.config.attribute name "identifier"}}'
      >
        <div
          class="
            tcolored
            tcenter
            thover
            ch-attribute-save-box
            grid-fill
            affix-icon
            {{#if (and
            @root/highlightModified
            (not (eq
            (path @root/system.attributes name 'competence.raw')
            (path @root/system._source.attributes name 'competence.raw'))))}}
              modified
            {{/if}}
          "
          data-action="increment"
          data-path="system.attributes.{{ name }}.competence.raw"
          data-tooltip='{{path @root/system.attributes name "competence.description"}}'
          data-tooltip-class=""
        >
          <i class='unselected {{path @root/attributeDisplay name "competenceIconClass"}}'></i>
          <i class='selected {{path @root/attributeDisplay name "sourceCompetenceIconClass"}}'></i>
        </div>
        <div
          class="tcenter thover draggable"
          style="text-transform: uppercase"
          data-action="rollFeatSave"
          data-attribute="{{ name }}"
          data-tooltip-direction="LEFT"
          data-uuid="{{lookup @root/attributeMacros name}}"
        >
          {{path @root/TERIOCK.config.attribute name "abbreviation"}}
        </div>
        <div
          class="
            tcenter
            affix
            {{#if (and
            @root/highlightModified
            (not (eq name 'unp'))
            (not (eq (path @root/system.attributes name 'score') (path @root/system._source.attributes name 'score'))))}}
              modified
            {{/if}}
          "
        >
          <div class="unselected">
            <span class="ch-attribute-input tcolored tcenter ttransparent">
              {{{path @root/system.attributes name "score"}}}
            </span>
          </div>
          {{formInput
            (path @root/systemFields "attributes.fields" name "fields.score")
            classes="ch-attribute-input tcolored tcenter ttransparent selected"
            dataset=(object noScroll="true")
            disabled=(eq name "unp")
            type="number"
            value=(ifThen
              (eq name "unp")
              @root/system.attributes.unp.score
              (path @root/system._source.attributes name "score"))
          }}
        </div>
        <div class="tcolored tcenter">{{sign (path @root/system.attributes name "value")}}</div>
      </div>
    {{/each}}
  </div>
</div>
