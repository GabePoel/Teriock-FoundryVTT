<div class="ch-battle-box tbox toutline">
  <div class="defense-box">
    <div class="defense-box-main">
      <div class="actor-shortbox actor-ac-box">
        <div class="tsubtle tcenter">{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.ac.label"}}</div>
        <div
          class="actor-smallbox-value"
          data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.ac.tooltip"}}'
        >
          {{{system.defense.ac}}}
        </div>
      </div>

      <div class="actor-shortbox actor-bv-box">
        <div class="tsubtle tcenter">{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.bv.label"}}</div>
        <div
          class="actor-smallbox-value"
          data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.bv.tooltip"}}'
        >
          {{{system.defense.bv}}}
        </div>
      </div>

      <div class="actor-shortbox actor-cc-box">
        <div class="tsubtle tcenter">{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.cc.label"}}</div>
        <div
          class="actor-smallbox-value"
          data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.cc.tooltip"}}'
        >
          {{{system.defense.cc}}}
        </div>
      </div>
    </div>

    <div class="actor-primary-blocker" style="width: 100%" data-action="selectBlocker">
      <div class="tsubtle little-title">
        <div class="title-left">{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.blockingWith"}}</div>
        <div class="title-right">
          <i
            class='{{makeIconClass TERIOCK.display.icons.ui.d20 "light"}} thover'
            data-action="rollAffinity"
            data-affinity-type="resistance"
            data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.rollResistance"}}'
          ></i>
          {{#if (exists system.wielding.blocker)}}
            <i
              class='{{makeIconClass TERIOCK.display.icons.interaction.block "light"}} thover'
              data-action="useAbility"
              data-ability="ability:basic-block"
              data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.rollBlock"}}'
            ></i>
            <i
              class='{{makeIconClass TERIOCK.display.icons.ui.openWindow "light"}} thover'
              data-action="openPrimaryBlocker"
              data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.open"}}'
            ></i>
          {{/if}}
        </div>
      </div>
      <div
        class="thover actor-primary-blocker-select draggable"
        data-tooltip-direction="LEFT"
        {{#if (exists system.wielding.blocker)}}
        data-tooltip-uuid="{{ system.wielding.blocker.uuid }}"
        {{/if}}
      >
        {{#if (exists system.wielding.blocker)}}
          {{{system.wielding.blocker.name}}}
        {{else}}
          {{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.none"}}
        {{/if}}
      </div>
    </div>
  </div>

  <div class="defense-box middle-box" style="flex-direction: row; width: 100%; gap: 0.5em">
    <div
      class="cover-box"
      data-action="increaseCover"
      data-tooltip-identifier="core:cover"
      data-tooltip-direction="LEFT"
    >
      <div class="title-left tsubtle">{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.CoverBox.label"}}</div>
      <div
        class="right-container thover"
        style="display: flex; align-items: center; justify-content: end; flex: 1"
        data-tooltip-class=""
        data-tooltip-direction="DOWN"
      >
        <i
          {{#if (eq system.cover 0)}}
          class='{{makeIconClass TERIOCK.display.icons.ui.off "solid"}}'
          data-tooltip='{{localize "TERIOCK.STATUSES.Cover.noCover"}}'
          {{/if}}
          {{#if (eq system.cover 1)}}
          class='{{makeIconClass TERIOCK.display.icons.cover.half "solid"}}'
          data-tooltip='{{localize "TERIOCK.STATUSES.Cover.halfCover"}}'
          {{/if}}
          {{#if (eq system.cover 2)}}
          class='{{makeIconClass TERIOCK.display.icons.cover.partial "solid"}}'
          data-tooltip='{{localize "TERIOCK.STATUSES.Cover.threeQuartersCover"}}'
          {{/if}}
          {{#if (eq system.cover 3)}}
          class='{{makeIconClass TERIOCK.display.icons.cover.full "solid"}}'
          data-tooltip='{{localize "TERIOCK.STATUSES.Cover.fullCover"}}'
          {{/if}}
        ></i>
      </div>
    </div>
    <div
      class="reaction-box"
      style="display: flex; align-items: center; flex-direction: row; width: 57%"
      data-action="toggleReaction"
    >
      <div class="title-left tsubtle">{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.ReactionBox.label"}}</div>
      <div class="right-container" style="display: flex; align-items: center; justify-content: end; flex: 1">
        <div
          class="actor-smallbox-value"
          data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.ReactionBox.tooltip"}}'
        >
          <i
            class='thover {{makeIconClass (lookup TERIOCK.display.icons.ui (ifThen system.combat.hasReaction "on" "off")) "light"}}'
          ></i>
        </div>
      </div>
    </div>
  </div>

  <div class="attack-box">
    <div class="attack-box-main">
      <div class="actor-shortbox actor-piercing-box">
        <div class="tsubtle tcenter">{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.piercing.label"}}</div>
        <div
          class="actor-smallbox-value thover"
          data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.piercing.tooltip"}}'
        >
          {{#if (or
            system.offense.piercing.ub
            system.wielding.attacker.system.piercing.ub)}}
            {{#if system.offense.piercing.ub}}
              {{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.ub.forced"}}
            {{else}}
              {{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.ub.normal"}}
            {{/if}}
          {{else}}
            {{#if (or
              system.offense.piercing.av0
              system.wielding.attacker.system.piercing.av0)}}
              {{#if system.offense.piercing.av0}}
                {{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.av0.forced"}}
              {{else}}
                {{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.av0.normal"}}
              {{/if}}
            {{else}}
              <i class='{{makeIconClass TERIOCK.display.icons.ui.off "light"}} thover'></i>
            {{/if}}
          {{/if}}
        </div>
      </div>

      <div class="actor-shortbox actor-sb-box" data-action="toggleSb">
        <div class="tsubtle tcenter">{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.sb.label"}}</div>
        <div
          class="actor-smallbox-value"
          data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.sb.tooltip"}}'
        >
          <i
            class='thover {{makeIconClass (path TERIOCK.display.icons.ui (ifThen system.offense.sb "on" "off")) "light"}}'
          ></i>
        </div>
      </div>

      <div class="actor-shortbox actor-penalty-box" data-action="resetAttackPenalty">
        <div class="tsubtle tcenter">{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.penalty.label"}}</div>
        {{
          formInput
          systemFields.combat.fields.attackPenalty
          value=system.combat.attackPenalty
          classes="actor-penalty-input actor-smallbox-value thover-soft"
          dataset=(object tooltip=(localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.penalty.tooltip"))
        }}
      </div>
    </div>

    <div class="actor-primary-attacker" style="width: 100%" data-action="selectAttacker">
      <div class="tsubtle little-title">
        <div class="title-left">{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.attackingWith"}}</div>
        <div class="title-right">
          <i
            class='{{makeIconClass TERIOCK.display.icons.interaction.attack "light"}} thover'
            data-action="useAbility"
            data-ability="ability:basic-attack"
            data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.rollAttack"}}'
          ></i>
          {{#if (exists system.wielding.attacker)}}
            <i
              class='{{makeIconClass TERIOCK.display.icons.effect.dealDamage "light"}} thover'
              data-action="quickUse"
              data-id="{{ system.wielding.attacker._id }}"
              data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.rollDamage"}}'
            ></i>
            <i
              class='{{makeIconClass TERIOCK.display.icons.ui.openWindow "light"}} thover'
              data-action="openPrimaryAttacker"
              data-tooltip='{{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.open"}}'
            ></i>
          {{/if}}
        </div>
      </div>

      <div
        class="thover actor-primary-attacker-select draggable"
        data-tooltip-direction="LEFT"
        {{#if (exists system.wielding.attacker)}}
        data-tooltip-uuid="{{ system.wielding.attacker.uuid }}"
        {{/if}}
      >
        {{#if (exists system.wielding.attacker)}}
          {{{system.wielding.attacker.name}}}
        {{else}}
          {{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.none"}}
        {{/if}}
      </div>

      {{#if (exists system.wielding.attacker.system.specialRules)}}
        <div class="tsubtle little-title" style="margin-top: 0.5em">
          {{path TERIOCK.reference.weaponFightingStyles system.wielding.attacker.system.fightingStyle}}
          {{localize "TERIOCK.SHEETS.Actor.SIDEBAR.BattleBox.fightingStyle"}}
        </div>
        <div class="actor-fighting-style-summary">
          {{{enrichedSpecialRules}}}
        </div>
      {{/if}}
    </div>
  </div>
</div>
