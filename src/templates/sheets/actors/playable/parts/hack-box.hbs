<div class="tgrid g7">
  {{#each TERIOCK.options.hack as |options part|}}
    <div
      class="thover hack-marker-box grid-fill"
      data-action="takeHack"
      data-part="{{part}}"
      data-tooltip="{{lookup options "label"}}"
    >
      <i class="fa-fw {{hackFill (lookup @root/system.hacks part)}} {{lookup options "icon"}}"></i>
    </div>
  {{/each}}
</div>