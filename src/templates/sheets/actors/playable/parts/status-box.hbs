<div class="actor-status-box">
  <div class="actor-status-bars">
    <div class="actor-status-bar-box">
      <div class="die-drawer top-drawer hack-drawer hp-drawer">
        {{> "teriock/sheets/actors/playable/parts/hack-box"}}
      </div>
      {{> "teriock/sheets/actors/playable/parts/bar-hp"}}
      <div
        class="
          die-drawer
          hp-die-drawer
          hp-drawer
          {{#if hpDrawerCollapsed}}
            collapsed
          {{/if}}
        "
      >
        {{> "teriock/ui/stat-dice"
          dice=system.hp.dice
        }}
      </div>
    </div>
    <div class="actor-status-bar-box">
      {{> "teriock/sheets/actors/playable/parts/bar-mp"}}
      <div
        class="
          die-drawer
          mp-die-drawer
          mp-drawer
          {{#if mpDrawerCollapsed}}
            collapsed
          {{/if}}
        "
      >
        {{> "teriock/ui/stat-dice"
          dice=system.mp.dice
        }}
      </div>
    </div>
    <div class="actor-status-bar-box">
      {{> "teriock/sheets/actors/playable/parts/bar-lp"}}
    </div>
    <div class="actor-status-bar-box">
      {{> "teriock/sheets/actors/playable/parts/bar-presence"}}
    </div>
  </div>
</div>
