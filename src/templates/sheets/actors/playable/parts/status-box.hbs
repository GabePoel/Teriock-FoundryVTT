<div class="character-status-box">
  <div class="character-status-bars">
    <div class="character-status-bar-box">
      <div class="die-drawer top-drawer hack-drawer hp-drawer">
        {{> "teriock/sheets/actors/playable/parts/hack-box"}}
      </div>
      {{> "teriock/sheets/actors/playable/parts/bar-hp"}}
      <div class="die-drawer hp-die-drawer hp-drawer {{#if hpDrawerCollapsed}}collapsed{{/if}}">
        <div class="tgrid g7">
          {{{system.sheet.dieBox.hp}}}
        </div>
      </div>
    </div>
    <div class="character-status-bar-box">
      {{> "teriock/sheets/actors/playable/parts/bar-mp"}}
      <div class="die-drawer mp-die-drawer mp-drawer {{#if mpDrawerCollapsed}}collapsed{{/if}}">
        <div class="tgrid g7">
          {{{system.sheet.dieBox.mp}}}
        </div>
      </div>
    </div>
    <div class="character-status-bar-box">
      {{> "teriock/sheets/actors/playable/parts/bar-wither"}}
    </div>
    <div class="character-status-bar-box">
      {{> "teriock/sheets/actors/playable/parts/bar-presence"}}
    </div>
  </div>
</div>
