<div
  class="
    teriock-block
    {{ classes }}
    {{#if draggable}}
      draggable
    {{/if}}
    {{#if inactive}}
      inactive
    {{else}}
      active
    {{/if}}
    {{#if struck}}
      struck
    {{/if}}
    {{#if shattered}}
      shattered
    {{/if}}
    {{#if hidden}}
      hidden
    {{/if}}
  "
  data-img="{{#if (exists img)}}img{{else}}systems/teriock/src/icons/documents/uncertainty.svg{{/if}}"
  {{#if identifier}}
    data-action="openIdentifier"
    data-identifier="{{ identifier }}"
  {{else if openable}}
    data-action="openDoc"
  {{/if}}
  {{#if uuid}}
    data-uuid="{{ uuid }}"
  {{/if}}
  {{#if tooltipIdentifier}}
    data-tooltip-identifier="{{ tooltipIdentifier }}"
  {{else if tooltipUuid}}
    data-tooltip-uuid="{{ tooltipUuid }}"
  {{else if uuid}}
    data-tooltip-uuid="{{ uuid }}"
  {{/if}}
  {{#if id}}
    data-id="{{ id }}"
  {{/if}}
  {{#if parentId}}
    data-parent-id="{{ parentId }}"
  {{/if}}
  {{#if type}}
    data-type="{{ type }}"
  {{/if}}
  {{#if relative}}
    data-relative="{{ relative }}"
  {{/if}}
  {{#if (exists tooltip)}}
    data-tooltip-html="{{ tooltip }}"
  {{/if}}
  {{#if (exists tooltipDirection)}}
    data-tooltip-direction="{{ tooltipDirection }}"
  {{else}}
    data-tooltip-direction="RIGHT"
  {{/if}}
  data-tooltip-class="teriock-rich-tooltip"
>
  <div
    class="
      teriock-block-image
      {{#if usable}}
        usable
      {{/if}}
    "
    {{#if color}}
      style="outline-color:{{ color }};"
    {{/if}}
    {{#if usable}}
      data-tooltip="{{localize "TERIOCK.MODELS.Usable.USAGE.use"}}"
      data-tooltip-direction="LEFT"
      data-tooltip-class=""
    {{/if}}
    {{#if action}}
      data-action="{{ action }}"
    {{/if}}
    data-shareable="true"
  >
    <img
      alt=""
      loading="lazy"
      src="{{#if (exists img)}}{{ img }}{{else}}systems/teriock/src/icons/documents/uncertainty.svg{{/if}}"
    />
  </div>
  <div class="teriock-block-body" data-tooltip-class="">
    <div class="teriock-block-titles">
      <div class="teriock-block-title">
        {{#if (exists title)}}
          {{ title }}
        {{else}}
          {{localize "TERIOCK.TERMS.Common.undefined"}}
        {{/if}}
      </div>
      <div
        class="
          teriock-block-subtitle
          {{#if subtitleAction}}
            teriock-block-clickable
          {{/if}}
        "
        {{#if subtitleAction}}
          data-action="{{ subtitleAction }}"
        {{/if}}
        {{#if subtitleTooltip}}
          data-tooltip-direction="DOWN"
          data-tooltip-class="teriock"
          data-tooltip="{{ subtitleTooltip }}"
        {{/if}}
      >
        {{ subtitle }}
      </div>
    </div>
    <div class="teriock-block-content">
      <div class="teriock-block-text">{{ text }}</div>
      <div class="teriock-block-icons" data-tooltip-direction="DOWN" data-tootip-class="teriock">
        {{#each icons}}
          <i
            class='
              ticon
              {{makeIconClass icon (ifThen (exists style) style "light")}}
              {{ classes }}
              {{#if (and clickable visible)}}
                teriock-block-clickable
              {{/if}}
            '
            {{#if (and (or (not (defined visible)) visible) action)}}
              data-action="{{ action }}"
            {{/if}}
            {{#if tooltip}}
              data-tooltip="{{ tooltip }}"
            {{/if}}
            {{#if dataset}}
              {{#each dataset as |value key|}}data-{{ key }}="{{ value }}"{{/each}}
            {{/if}}
          ></i>
        {{/each}}
      </div>
    </div>
  </div>
  <div class="teriock-block-background"></div>
</div>
