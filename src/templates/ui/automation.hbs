<div
  class="teriock-automation-container collapsable{{#if automationCollapsed}} collapsed{{/if}}"
  data-automation-id="{{automation.id}}"
>
  <header
    class="teriock-automation-header draggable"
    data-action="toggleAutomationCollapse"
    data-uuid="{{automation.puuid}}"
  >
    <div class="teriock-automation-header-name">{{localize automation.label}}</div>
    <div class="teriock-automation-header-buttons">
      {{#if automation.canCrit}}
        <div class="teriock-automation-header-button-group">
          <button
            id="{{automation.uuid}}.noncrit"
            data-action="setToggle"
            data-type="number"
            data-term="0"
            {{#if (includes automation.crit 0)}}
            data-present="true"
            data-tooltip="{{localize "TERIOCK.AUTOMATIONS.Base.TOOLTIPS.crit.base.on"}}"
            {{else}}
            data-tooltip="{{localize "TERIOCK.AUTOMATIONS.Base.TOOLTIPS.crit.base.off"}}"
            {{/if}}
            data-path="{{automation.localPath}}.crit"
            name="_source.{{automation.localPath}}.crit"
          >
            {{makeIcon @root/TERIOCK.display.icons.consequence.none (ifThen
              (includes automation.crit 0)
              "solid"
              "light"
            )}}
          </button>
          <button
            id="{{automation.uuid}}.crit"
            data-action="setToggle"
            data-type="number"
            data-term="1"
            {{#if (includes automation.crit 1)}}
            data-present="true"
            data-tooltip="{{localize "TERIOCK.AUTOMATIONS.Base.TOOLTIPS.crit.critical.on"}}"
            {{else}}
            data-tooltip="{{localize "TERIOCK.AUTOMATIONS.Base.TOOLTIPS.crit.critical.off"}}"
            {{/if}}
            data-path="{{automation.localPath}}.crit"
            name="_source.{{automation.localPath}}.crit"
          >
            {{makeIcon @root/TERIOCK.display.icons.consequence.crit (ifThen
              (includes automation.crit 1)
              "solid"
              "light"
            )}}
          </button>
        </div>
      {{/if}}
      {{#if @root/system.competence}}
        <div class="teriock-automation-header-button-group">
          <button
            id="{{automation.uuid}}.base"
            data-action="setToggle"
            data-type="number"
            data-term="0"
            {{#if (includes automation.competencies 0)}}
            data-present="true"
            data-tooltip="{{localize "TERIOCK.AUTOMATIONS.Base.TOOLTIPS.competence.base.on"}}"
            {{else}}
            data-tooltip="{{localize "TERIOCK.AUTOMATIONS.Base.TOOLTIPS.competence.base.off"}}"
            {{/if}}
            data-path="{{automation.localPath}}.competencies"
            name="_source.{{automation.localPath}}.competencies"
          >
            {{makeIcon @root/TERIOCK.display.icons.competence.none (ifThen
              (includes automation.competencies 0)
              "solid"
              "light"
            )}}
          </button>
          <button
            id="{{automation.uuid}}.proficient"
            data-action="setToggle"
            data-type="number"
            data-term="1"
            {{#if (includes automation.competencies 1)}}
            data-present="true"
            data-tooltip="{{localize "TERIOCK.AUTOMATIONS.Base.TOOLTIPS.competence.proficient.on"}}"
            {{else}}
            data-tooltip="{{localize "TERIOCK.AUTOMATIONS.Base.TOOLTIPS.competence.proficient.off"}}"
            {{/if}}
            data-path="{{automation.localPath}}.competencies"
            name="_source.{{automation.localPath}}.competencies"
          >
            {{makeIcon @root/TERIOCK.display.icons.competence.proficient (ifThen
              (includes automation.competencies 1)
              "solid"
              "light"
            )}}
          </button>
          <button
            id="{{automation.uuid}}.fluent"
            data-action="setToggle"
            data-type="number"
            data-term="2"
            {{#if (includes automation.competencies 2)}}
            data-present="true"
            data-tooltip="{{localize "TERIOCK.AUTOMATIONS.Base.TOOLTIPS.competence.fluent.on"}}"
            {{else}}
            data-tooltip="{{localize "TERIOCK.AUTOMATIONS.Base.TOOLTIPS.competence.fluent.off"}}"
            {{/if}}
            data-path="{{automation.localPath}}.competencies"
            name="_source.{{automation.localPath}}.competencies"
          >
            {{makeIcon @root/TERIOCK.display.icons.competence.fluent (ifThen
              (includes automation.competencies 2)
              "solid"
              "light"
            )}}
          </button>
        </div>
      {{/if}}
      {{#if (eq automation.document.type "ability")}}
        <div class="teriock-automation-header-button-group">
          <button
            id="{{automation.uuid}}.unheightened"
            data-action="setToggle"
            data-type="number"
            data-term="0"
            {{#if (includes automation.heighten 0)}}
            data-present="true"
            data-tooltip="{{localize "TERIOCK.AUTOMATIONS.Base.TOOLTIPS.heighten.base.on"}}"
            {{else}}
            data-tooltip="{{localize "TERIOCK.AUTOMATIONS.Base.TOOLTIPS.heighten.base.off"}}"
            {{/if}}
            data-path="{{automation.localPath}}.heighten"
            name="_source.{{automation.localPath}}.heighten"
          >
            {{makeIcon @root/TERIOCK.display.icons.ability.unheightened (ifThen
              (includes automation.heighten 0)
              "solid"
              "light"
            )}}
          </button>
          <button
            id="{{automation.uuid}}.heightened"
            data-action="setToggle"
            data-type="number"
            data-term="1"
            {{#if (includes automation.heighten 1)}}
            data-present="true"
            data-tooltip="{{localize "TERIOCK.AUTOMATIONS.Base.TOOLTIPS.heighten.heightened.on"}}"
            {{else}}
            data-tooltip="{{localize "TERIOCK.AUTOMATIONS.Base.TOOLTIPS.heighten.heightened.off"}}"
            {{/if}}
            data-path="{{automation.localPath}}.heighten"
            name="_source.{{automation.localPath}}.heighten"
          >
            {{makeIcon @root/TERIOCK.display.icons.ability.heightened (ifThen
              (includes automation.heighten 1)
              "solid"
              "light"
            )}}
          </button>
        </div>
      {{/if}}
      <div class="teriock-automation-header-button-group">
        <button
          data-tooltip="{{localize "TERIOCK.SYSTEMS.Common.MENU.delete"}}"
          data-action="deleteAutomation"
          data-id="{{automation.id}}"
        >
          {{makeIcon @root/TERIOCK.display.icons.ui.delete "button"}}
        </button>
      </div>
    </div>
  </header>
  <div class="teriock-automation-collapse-target">
    <div class="teriock-automation-spacer">
      <div class="teriock-automation-content teriock-form-container">
        {{#if (exists messages)}}
          <ul class="notification-container">
            {{#each messages as |message|}}
              <li class="notification {{#if message.level}}{{message.level}}{{else}}info{{/if}}">
                <span>{{localize message.text}}</span>
              </li>
            {{/each}}
          </ul>
        {{/if}}
        {{{formEditor}}}
      </div>
    </div>
  </div>
</div>
