{{!-- Blatantly stolen from D&D 5E --}}
{{!-- TODO: Work around core issue with providing undefined name --}}
{{#each this}}
  {{#if name}}
    {{formGroup
      field
      name=name
      value=value
      input=input
      options=options
      disabled=disabled
      localize=localize
      placeholder=placeholder
      label=label
      hint=hint
      classes=classes
      rootId=@root.partId
    }}
  {{else}}
    {{formGroup
      field
      value=value
      input=input
      options=options
      disabled=disabled
      localize=localize
      placeholder=placeholder
      label=label
      hint=hint
      classes=classes
      rootId=@root.partId
    }}
  {{/if}}
{{/each}}
