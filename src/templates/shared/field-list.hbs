{{!-- Blatantly stolen from D&D 5E --}}
{{!-- TODO: Work around core issue with providing undefined name --}}
{{#each this}}
  {{#if name}}
    {{formGroup
      field
      choices=choices
      classes=classes
      disabled=disabled
      hint=hint
      input=input
      label=label
      localize=localize
      name=name
      options=options
      placeholder=placeholder
      reset=reset
      rootId=@root.partId
      value=value
    }}
  {{else}}
    {{formGroup
      field
      choices=choices
      classes=classes
      disabled=disabled
      hint=hint
      input=input
      label=label
      localize=localize
      options=options
      placeholder=placeholder
      reset=reset
      rootId=@root.partId
      value=value
    }}
  {{/if}}
{{/each}}
