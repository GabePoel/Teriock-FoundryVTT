{
  "authors": [
    {
      "discord": "gpoel",
      "name": "Gabriel Perko-Engel"
    }
  ],
  "background": "systems/teriock/src/assets/splash.webp",
  "bugs": "https://github.com/gabepoel/Teriock-FoundryVTT/issues",
  "compatibility": {
    "maximum": 14,
    "minimum": 14,
    "verified": 14
  },
  "description": "Foundry VTT implementation of Teriock (FanWar).",
  "documentTypes": {
    "ActiveEffect": {
      "ability": {
        "filePathFields": {
          "automations.*.img": ["IMAGE"]
        },
        "htmlFields": [
          "consumeSourceText",
          "costs.components.*.description",
          "costs.primary.*.description",
          "elderSorceryIncant",
          "endCondition",
          "grantOnlyText",
          "grantUseText",
          "heightened",
          "improvement",
          "limitation",
          "overview.*",
          "requirements",
          "results.*",
          "trigger",
          "upgrades.*.text"
        ]
      },
      "attunement": {
        "htmlFields": ["description"]
      },
      "condition": {
        "filePathFields": {
          "transformation.img": ["IMAGE"]
        },
        "htmlFields": ["description"]
      },
      "consequence": {
        "filePathFields": {
          "transformation.img": ["IMAGE"],
          "associations.*.cards.*.img": ["IMAGE"]
        },
        "htmlFields": ["description"]
      },
      "cover": {},
      "fluency": {
        "htmlFields": ["description", "tradecraftDescription"]
      },
      "hack": {},
      "imbuement": {
        "filePathFields": {
          "associations.*.cards.*.img": ["IMAGE"]
        },
        "htmlFields": ["description"]
      },
      "property": {
        "htmlFields": ["description", "limitation", "improvement"]
      },
      "resource": {
        "htmlFields": ["description"]
      }
    },
    "Actor": {
      "character": {
        "htmlFields": ["notes"]
      },
      "creature": {
        "htmlFields": ["notes"]
      },
      "inventory": {
        "htmlFields": ["notes"]
      }
    },
    "Card": {
      "card": {},
      "stone": {}
    },
    "Item": {
      "archetype": {
        "htmlFields": ["description", "flaws"]
      },
      "body": {
        "htmlFields": ["description", "flaws", "notes", "specialRules"]
      },
      "equipment": {
        "htmlFields": ["description", "flaws", "notes", "specialRules"]
      },
      "mount": {
        "htmlFields": ["description", "flaws"]
      },
      "power": {
        "htmlFields": ["description", "flaws"]
      },
      "rank": {
        "htmlFields": ["description", "flaws"]
      },
      "species": {
        "filePathFields": {
          "transformation.img": ["IMAGE"]
        },
        "htmlFields": [
          "appearance",
          "attributeIncrease",
          "description",
          "flaws",
          "hpIncrease",
          "innateRanks",
          "mpIncrease"
        ]
      }
    },
    "JournalEntryPage": {
      "damage": {
        "filePathFields": {
          "img": ["IMAGE"]
        }
      },
      "drain": {
        "filePathFields": {
          "img": ["IMAGE"]
        }
      }
    }
  },
  "download": "https://github.com/gabepoel/Teriock-FoundryVTT/releases/latest/download/release.zip",
  "esmodules": ["src/module/teriock.mjs"],
  "flags": {
    "hotReload": {
      "extensions": ["css", "html", "hbs", "json"],
      "paths": ["css", "src", "templates"]
    }
  },
  "grid": {
    "diagonals": 0,
    "distance": 5,
    "type": 1,
    "units": "ft"
  },
  "id": "teriock",
  "languages": [
    {
      "lang": "en",
