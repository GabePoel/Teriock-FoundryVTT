{
  "name": "teriock",
  "version": "3.0.0",
  "description": "Scripts to manage Teriock Foundry VTT system.",
  "scripts": {
    "build": "run-s compendium:pack build:*",
    "build:lang": "node scripts/build-lang.mjs",
    "build:style": "sass src/style/teriock.scss css/teriock.css --style=expanded",
    "build:symbols": "node scripts/build-symbols.mjs",
    "build:templates": "node scripts/build-templates.mjs",
    "build:zip": "node scripts/build-zip.mjs",
    "compendium:compile": "node scripts/compendium-compile.mjs",
    "compendium:pack": "node scripts/compendium-pack.mjs",
    "compendium:uncompile": "node scripts/compendium-uncompile.mjs",
    "compendium:unpack": "node scripts/compendium-unpack.mjs",
    "format:check": "dprint check && prettier . --check",
    "format:fix": "dprint fmt && prettier . --write",
    "link:foundry": "node scripts/link-foundry.mjs",
    "lint:check": "eslint src/module/teriock.mjs src/module/**/*",
    "lint:fix": "eslint --fix src/module/teriock.mjs src/module/**/*",
    "prepare:check": "run-s lint:check format:check",
    "prepare:fix": "run-s lint:fix format:fix"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "Gabriel",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@foundryvtt/foundryvtt-cli": "^3.0.3",
    "@mdi/font": "^7.4.47",
    "@poliklot/prettier-plugin-handlebars": "^0.2.11",
    "archiver": "^7.0.1",
    "dprint": "^0.54.0",
    "eslint": "^9.36.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "globals": "^16.4.0",
    "js-yaml": "4.1.1",
    "jsdom": "^26.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "3.6.2",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "sass": "^1.89.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.44.1"
  }
}
