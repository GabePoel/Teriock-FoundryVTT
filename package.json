{
  "author": "Gabriel",
  "browserslist": [
    "last 3 versions"
  ],
  "description": "Scripts to manage Teriock Foundry VTT system.",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@foundryvtt/foundryvtt-cli": "^3.0.4",
    "@mdi/font": "^7.4.47",
    "@poliklot/prettier-plugin-handlebars": "^0.3.2",
    "archiver": "^8.0.0",
    "dprint": "^0.55.2",
    "eslint": "^10.7.0",
    "eslint-plugin-jsdoc": "^63.2.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "globals": "^17.7.0",
    "js-yaml": "5.2.1",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "prettier": "3.9.5",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "name": "teriock",
  "private": true,
  "scripts": {
    "build": "run-s compendium:pack build:*",
    "build:hold-icons": "node scripts/build/hold-icons.mjs",
    "build:lang": "node scripts/build/lang.mjs",
    "build:manifest": "node scripts/build/manifest.mjs",
    "build:style": "sass src/style/teriock.scss css/teriock.css --style=expanded",
    "build:templates": "node scripts/build/templates.mjs",
    "build:zip": "node scripts/build/zip.mjs && npm run format:json-sort && dprint fmt",
    "compendium:compile": "node scripts/compendium/compile.mjs",
    "compendium:pack": "node scripts/compendium/pack.mjs",
    "compendium:uncompile": "node scripts/compendium/uncompile.mjs",
    "compendium:unpack": "node scripts/compendium/unpack.mjs && run-s format:dprint",
    "format:check": "dprint check && prettier . --check",
    "format:dprint": "dprint fmt",
    "format:fix": "npm run format:json-sort && dprint fmt && prettier . --write",
    "format:json-sort": "prettier --ignore-path /dev/null --write \"**/*.json\"",
    "link:foundry": "node scripts/link/foundry.mjs",
    "link:symbols": "node scripts/link/symbols.mjs",
    "lint:check": "eslint src/module/teriock.mjs src/module/**/*",
    "lint:fix": "eslint --fix src/module/teriock.mjs src/module/**/*",
    "prepare:check": "run-s lint:check format:check",
    "prepare:fix": "run-s lint:fix format:fix"
  },
  "version": "3.1.1"
}
